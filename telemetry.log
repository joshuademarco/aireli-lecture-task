22445dd5cf5fc58f616c","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":27,"operation":"replace","value":"r","rangeOffset":"0","rangeLength":"1677","rangestart_line":"0","rangestart_character":"0","rangeend_line":"61","rangeend_character":"2"},{"codespaceName":"refactored-potato-7pvxwr5r675fp7vq","eventName":"DocumentChangeEvent","eventTime":1773786095116,"sessionId":"32f7ec21-2c5b-4ddc-b162-6e91a42e156d1773784157194","machineId":"ecdaed6562c342f7c94a91be861f058948b9d02bcb7722445dd5cf5fc58f616c","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":27,"operation":"replace","value":"import { PlatformAccessToken, PlatformUserCreateInput, PlatformUser } from '@enterprise-commerce/core/platform/types';\nimport axios from 'axios';\nimport { Request, Response } from 'express';\nimport jwt from 'jsonwebtoken';\n\nconst registerUser = async (input: PlatformUserCreateInput): Promise<Pick<PlatformUser, \"id\"> | undefined | null> => {\n try {\n  const response = await fetch('http://localhost:3001/register', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n    },\n    body: JSON.stringify(input),\n  });\n\n  if (!response.ok) {\n    return null;\n  }\n\n  retrun\n\n\n }\n  return null\n};\n\nconst loginUser = async (input: PlatformUserCreateInput) => {\n  // ToDo: Implement the loginUser function (someone else is working on it)\n  const user = {id: null} // replace this line\n\n\n  // The following lines can be left unchanged because the output is expected to be a JWT token and an expiresAt value\n  const accessToken = jwt.sign({ id: user?.id }, process.env.JWT_SECRET || \"no_key_set\" as string, { expiresIn: '1h' });\n  const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString(); // 3600 seconds = 1 hour\n  return { accessToken, expiresAt };\n};\n\nconst getUser = async (accessToken: string): Promise<PlatformUser | undefined | null> => {\n  try {\n    if(accessToken != \"\") {\n      const { data } = await axios.get('http://localhost:3001/me', {\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n        },\n      });\n\n      return data.user;\n    } else {\n      return null\n    }\n  } catch (error) {\n    console.error(error);\n    // Handle error\n    return null;\n  }\n};\n\nexport default {\n  registerUser,\n  loginUser,\n  getUser\n};","rangeOffset":"0","rangeLength":"1","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"1"},{"codespaceName":"refactored-potato-7pvxwr5r675fp7vq","eventName":"DocumentChangeEvent","eventTime":1773786101018,"sessionId":"32f7ec21-2c5b-4ddc-b162-6e91a42e156d1773784157194","machineId":"ecdaed6562c342f7c94a91be861f058948b9d02bcb7722445dd5cf5fc58f616c","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":27,"operation":"delete","value":"","rangeOffset":"587","rangeLength":"6","rangestart_line":"19","rangestart_character":"2","rangeend_line":"19","rangeend_character":"8"},{"codespaceName":"refactored-potato-7pvxwr5r675fp7vq","eventName":"DocumentChangeEvent","eventTime":1773786101297,"sessionId":"32f7ec21-2c5b-4ddc-b162-6e91a42e156d1773784157194","machineId":"ecdaed6562c342f7c94a91be861f058948b9d02bcb7722445dd5cf5fc58f616c","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":27,"operation":"add","value":"r","rangeOffset":"587","rangeLength":"0","rangestart_line":"19","rangestart_character":"2","rangeend_line":"19","rangeend_character":"2"},{"codespaceName":"refactored-potato-7pvxwr5r675fp7vq","eventName":"DocumentChangeEvent","eventTime":1773786101506,"sessionId":"32f7ec21-2c5b-4ddc-b162-6e91a42e156d1773784157194","machineId":"ecdaed6562c342f7c94a91be861f058948b9d02bcb7722445dd5cf5fc58f616c","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":27,"operation"